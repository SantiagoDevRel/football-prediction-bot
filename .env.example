# Datos: ESPN (sin auth) + football-data.co.uk (CSV público) → NO requieren key.
# Si en el futuro agregamos un proveedor con auth, declarar acá.

# Anthropic (para features cualitativas con Claude)
ANTHROPIC_API_KEY=

# Telegram bot (notificaciones)
# Crear con @BotFather en Telegram, te da el token
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Modo de operación: "paper" (simulado) o "real" (plata real)
# Default: paper. Cambiar a "real" SOLO después de 100+ picks con CLV positivo.
BETTING_MODE=paper

# Bankroll virtual de paper trading (COP)
PAPER_BANKROLL_INITIAL=1000000

# Kelly fraction (¼ Kelly = 0.25, recomendado)
KELLY_FRACTION=0.25

# Edge mínimo para considerar una apuesta (5% = 0.05)
MIN_EDGE=0.05

# Edge máximo: arriba de esto casi siempre es bug del modelo, no value real.
# Cualquier "oportunidad" con edge > 30% se filtra automáticamente.
MAX_EDGE=0.30

# Confianza mínima del modelo bayesiano para apostar
MIN_CONFIDENCE=0.60

# DB local
DATABASE_URL=sqlite:///data/db/football_bot.db

# Log level
LOG_LEVEL=INFO
